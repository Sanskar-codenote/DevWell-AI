# ─── DevWell Docker Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in ALL values before starting production.
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d

# ─── Ports ────────────────────────────────────────────────────────────────────
FRONTEND_PORT=80
BACKEND_PORT=3001

# ─── Security (MUST CHANGE) ──────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=

# ─── Database ────────────────────────────────────────────────────────────────
DB_USER=devwell
DB_PASSWORD=
DB_HOST=db
DB_NAME=devwell_production
DB_PORT=5432
DB_POOL_MAX=20

# ─── CORS (comma-separated, REQUIRED in production) ─────────────────────────
# Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=

# ─── Chrome Extension (REQUIRED in production) ──────────────────────────────
# Set to your published Chrome extension ID
EXTENSION_ID=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
