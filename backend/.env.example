PORT=3001
FRONTEND_PORT=5173
JWT_SECRET=your_strong_secret_here
DB_USER=dev16
DB_HOST=/var/run/postgresql
DB_NAME=devwell_dev
DB_PORT=5432
# Set for DB auth (required in Dockerized Postgres)
# DB_PASSWORD=postgres
# Optional CORS override, comma-separated
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional: lock CORS to specific published extension
# EXTENSION_ID=your_chrome_extension_id

# ── Email / OTP (SMTP) configuration ──────────────────────────────────────────
#
# For Gmail / Google Workspace:
#   1. Enable 2-Factor Authentication on your Google account.
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#      (Select app: "Mail", Device: "Other").
#   3. Copy the 16-character App Password and paste it below as SMTP_PASS.
#   4. Use your full Gmail address for SMTP_USER and SMTP_FROM.
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=your_email@gmail.com
#
# For SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=your_sendgrid_api_key
#   SMTP_FROM=noreply@yourdomain.com
