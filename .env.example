# DevWell unified environment template
# Copy to `.env` and set values for your environment.

# Shared ports
FRONTEND_PORT=5173
BACKEND_PORT=3001
PORT=3001

# Backend security
JWT_SECRET=change_me

# Database
DB_USER=devwell
DB_PASSWORD=change_me
DB_HOST=localhost
DB_NAME=devwell_dev
DB_PORT=5432
DB_POOL_MAX=20
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# CORS / extension
# Example: http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=
EXTENSION_ID=

# Backend logging
LOG_LEVEL=info
JWT_EXPIRES_IN=7d
OTP_EXPIRY_MINUTES=10
MAX_PENDING_OTP_PER_EMAIL=3
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RATE_LIMIT_MAX=3
API_RATE_LIMIT_WINDOW_MINUTES=15
API_RATE_LIMIT_MAX=100
CSP_CONNECT_SRC=https://*.railway.app

# Optional SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Chrome extension settings
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001

# Frontend dev proxy (optional)
VITE_API_PROXY_HOST=localhost
VITE_API_PROXY_PORT=3001
# VITE_API_PROXY_TARGET=http://localhost:3001
